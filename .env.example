# 复制本文件为 .env 后填入真实凭证。.env 不会被提交到 git。

# ────── 火山引擎 · 豆包端到端实时语音 ──────
# 控制台路径：豆包语音 → 应用管理 → 你的应用详情
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=

# 可选：要换音色就改这个，realtime/dialogue 官方支持的音色：
#   zh_female_vv_jupiter_bigtts      （vv，活泼）
#   zh_female_xiaohe_jupiter_bigtts  （小荷，默认）
#   zh_male_yunzhou_jupiter_bigtts   （云舟）
#   zh_male_xiaotian_jupiter_bigtts  （小天）
# DOUBAO_SPEAKER=zh_female_xiaohe_jupiter_bigtts

# ────── Spectra (你的知识库 agent 平台) ──────
SPECTRA_TOKEN=
SPECTRA_AGENT_ID=
# 如果你 Spectra 接口域名不一样，改这个。否则不用动。
# SPECTRA_URL=https://api-spectra.duplik.cn/v1/conversations

# ────── 其他可选 ──────
# BOT_NAME=黄老师课程助教
